<!DOCTYPE html>
<html lang="fi">
<head>
  <meta charset="UTF-8">
  <meta name="viewport" content="width=device-width, initial-scale=1.0">
  <title>Tekoälyoppimissuunnitelma – Unelmatyökalu</title>
  <style>
    body {
      font-family: system-ui, -apple-system, sans-serif;
      max-width: 700px;
      margin: 2rem auto;
      padding: 1rem;
      background: #fdfdfd;
      color: #1e1e1e;
    }
    h1 { color: #2c3e50; }
    textarea {
      width: 100%;
      height: 120px;
      padding: 1rem;
      font-size: 1rem;
      border-radius: 10px;
      border: 2px solid #ddd;
      margin: 1rem 0 0.5rem;
      resize: vertical;
    }
    button {
      background: #0077b6;
      color: white;
      border: none;
      padding: 0.8rem 2rem;
      font-size: 1rem;
      border-radius: 25px;
      cursor: pointer;
      transition: background 0.2s;
    }
    button:hover { background: #005f8c; }
    button:disabled { background: #aaa; cursor: not-allowed; }

    #tulos {
      white-space: pre-wrap;
      background: #f0f4f8;
      padding: 1.5rem;
      margin-top: 1.5rem;
      border-radius: 12px;
      line-height: 1.6;
      display: none;
    }
    .loader {
      display: none;
      margin: 1rem 0;
      color: #0077b6;
    }
  </style>
</head>
<body>
  <h1>✨ Mikä on unelmasi?</h1>
  <p>Kerro vapaasti, mitä haluat saavuttaa. Tekoäly auttaa löytämään tarvittavat taidot ja näyttää, <strong>miten juuri sinä voit hyödyntää tekoälyä</strong> unelmasi tavoittelussa.</p>
  <textarea id="unelma" placeholder="Esim. Haluan perustaa kestävän muodin verkkokaupan ja elää sillä..."></textarea>
  <button id="lahetaBtn" onclick="laheta()">Luo oppimissuunnitelma</button>
  <div class="loader" id="lataus">⏳ Tekoäly laatii suunnitelmaasi...</div>
  <div id="tulos"></div>

  <script>
    async function laheta() {
      const unelma = document.getElementById('unelma').value.trim();
      const tulos = document.getElementById('tulos');
      const lataus = document.getElementById('lataus');
      const nappi = document.getElementById('lahetaBtn');

      if (unelma.length < 5) {
        alert('Kirjoita hieman pidempi unelma, kiitos!');
        return;
      }

      tulos.style.display = 'none';
      lataus.style.display = 'block';
      nappi.disabled = true;

      try {
        const response = await fetch('/api/unelma', {
          method: 'POST',
          headers: { 'Content-Type': 'application/json' },
          body: JSON.stringify({ dream: unelma })
        });

        const data = await response.json();
        if (!response.ok) throw new Error(data.error || 'Tuntematon virhe');
        tulos.innerText = data.plan;
        tulos.style.display = 'block';
      } catch (error) {
        tulos.innerText = '❌ ' + error.message;
        tulos.style.display = 'block';
      } finally {
        lataus.style.display = 'none';
        nappi.disabled = false;
      }
    }
  </script>
</body>
</html>